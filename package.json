{
  "name": "taulukko-commons",
  "version": "1.3.0",
  "type": "commonjs",
  "description": "Taulukko Commons Library",
  "private": false,
  "author": "Taulukko Inc.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "lint": "tslint --exclude '**/*.temp.ts' --exclude '**/node_modules/**' -p . ",
    "tsfm": "tsfmt -r --no-tslint",
    "build": "rimraf ./dist && tsc -p tsconfig.json --sourceMap",
    "test":"clear && jest"
  },
  "devDependencies": {
    "@google-cloud/nodejs-repo-tools": "^3.3.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^24.0.15",
    "jest": "^24.9.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^24.0.2",
    "tslint": "^5.11.0",
    "tslint-eslint-rules-recommended": "^1.2.2"
  }, 
  "dependencies": {
    "node-cache": "^5.1.2"
  }
}
